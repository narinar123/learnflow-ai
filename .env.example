# ─────────────────────────────────────────────────────────────────────────────
# GUIDESOFT IT SOLUTIONS — Environment Variables Template
# Copy this to .env.local and fill in real values before running locally.
# For production (Coolify / Vercel), set these as environment variables in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection URL (Neon, Supabase, or self-hosted)
DATABASE_URL="postgresql://user:password@host:5432/guidesoft_db?schema=public"

# ─── NEXT.JS / APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="GUIDESOFT IT SOLUTIONS"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-with: openssl rand -base64 64"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── RAZORPAY (India Payments) ────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# ─── STRIPE (International Payments) ─────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ─── GOOGLE AI / GEMINI ──────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─── FIREBASE (Push Notifications & Storage) ─────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy-your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"

# ─── EMAIL (Resend / SendGrid / SMTP) ────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@guidesoft.com"

# ─── CLOUD STORAGE (Cloudflare R2 / AWS S3) ──────────────────────────────────
STORAGE_BUCKET_NAME="guidesoft-media"
STORAGE_ACCESS_KEY_ID="your-access-key-id"
STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"
STORAGE_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
NEXT_PUBLIC_STORAGE_CDN_URL="https://cdn.guidesoft.com"

# ─── REDIS (Rate limiting, sessions, queues) ──────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── NODE ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
